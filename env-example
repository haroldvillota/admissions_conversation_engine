RAG__VECTOR_STORE__KIND="postgresql"
RAG__VECTOR_STORE__DSN="from_key_vault/admission-rag-vector-store-dsn" # Secret: use from_key_vault/<secret-name> to fetch from Azure Key Vault
RAG__VECTOR_STORE__COLLECTION="rag_docs"
RAG__VECTOR_STORE__TOP_K="4"

RAG__EMBEDDINGS__PROVIDER="openai"
RAG__EMBEDDINGS__API_KEY="from_key_vault/admission-rag-embeddings-api-key" # Optional: si no está, usa LLM__DEFAULT__API_KEY
RAG__EMBEDDINGS__MODEL="text-embedding-3-large"
RAG__EMBEDDINGS__BATCH_SIZE="128"

LLM__DEFAULT__PROVIDER="openai"
LLM__DEFAULT__API_KEY="from_key_vault/admission-llm-default-api-key" # Secret
LLM__DEFAULT__MODEL="gpt-4o-mini"
LLM__DEFAULT__TEMPERATURE="0.0"

LLM__GUARDRAIL__MODEL="gpt-4.1-nano"
LLM__GUARDRAIL__TEMPERATURE="0.0"

LLM__REACT__MODEL="gpt-4.1-mini"
LLM__REACT__TEMPERATURE="0.0"

LLM__TRANSLATOR__MODEL="gpt-4.1-nano"
LLM__TRANSLATOR__TEMPERATURE="0.0"

CHECKPOINTER__KIND="postgresql"
CHECKPOINTER__DSN="from_key_vault/admission-checkpointer-dsn" # Secret

OBSERVABILITY__PROVIDER="langfuse"
OBSERVABILITY__PUBLIC_KEY="from_key_vault/admission-observability-public-key" # Secret
OBSERVABILITY__SECRET_KEY="from_key_vault/admission-observability-secret-key" # Secret
OBSERVABILITY__BASE_URL="https://cloud.langfuse.com"

TENANT__INSTITUTION="Universidad Europea"
TENANT__TERMS_OF_SERVICE="https://universidadeuropea.com/conocenos/normativa/"
TENANT__ALLOWED_TOPICS="Información de carreras,Admisiones"
TENANT__TONE="Siempre utiliza la segunda persona singular (\"tú\"), manteniendo un tono amigable, respetuoso y empático."
TENANT__LANGUAGE_FALLBACK="en-US"
TENANT__ALLOWED_LANGUAGES="es-ES,en-US"

AUTH__JWT_SECRET_KEY="change-me-use-a-strong-random-secret"
AUTH__JWT_ALGORITHM="HS256"
AUTH__JWT_EXPIRE_MINUTES="60"

# Required when any variable uses the from_key_vault/<secret-name> syntax
USE_VAULT=1
AZURE_KEY_VAULT_URL="https://<vault-name>.vault.azure.net/"

